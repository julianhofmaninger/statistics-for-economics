min_periodsincome <- min(data$periodsincome)
max_periodsincome <- max(data$periodsincome)
if(x_vertex >= min_periodsincome & x_vertex <= max_periodsincome){
paste("The vertex (", round(x_vertex,3) ,") lies within the range (", round(min_periodsincome, 3), ";", round(max_periodsincome,3), ") of periodsincome: Non monotonic effect", sep="")
}else{
print("The vertex does not lie within the range of periodsincome: Monotone effect")
}
x_vertex <- -linear_model2$coefficients["periodsincome"]/(2*linear_model2$coefficients["I(periodsincome^2)"])
