# 1. LINEARITY: Residuals vs Fitted (random scatter, no pattern)
plot(linear_model3$fitted.values, linear_model3$residuals,
xlab="Fitted Values", ylab="Residuals",
main="1. Linearity Check")
abline(h=0, col="red", lwd=2)
# 2. HOMOSCEDASTICITY: Scale-Location (flat trend line)
plot(linear_model3$fitted.values, sqrt(abs(residuals(linear_model3))),
xlab="Fitted Values", ylab="√|Standardized Residuals|",
main="2. Homoscedasticity Check")
lines(lowess(lowess(linear_model3$fitted.values, sqrt(abs(residuals(linear_model3))))),
col="red", lwd=2)
# 3. NORMALITY: Q-Q Plot (points follow line)
qqnorm(residuals(linear_model3), main="3. Normality Check")
qqline(residuals(linear_model3), col="red", lwd=2)
# 4. INDEPENDENCE: Residuals vs Order (random scatter)
plot(1:nobs(linear_model3), residuals(linear_model3),
xlab="Observation Order", ylab="Residuals",
main="4. Independence Check")
abline(h=0, col="red", lwd=2)
resids <- residuals(linear_model3)
plot(linear_model3, which=1)
abline(h=0, lty=2, col="red")
plot(resids ~ data$age)
plot(resids ~ data$periodsincome)
